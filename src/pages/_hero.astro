      <path d="M450.5 497C463.479 497 474 507.521 474 520.5C474 533.479 463.479 544 450.5 544C437.521 544 427 533.479 427 520.5C427 507.521 437.521 497 450.5 497ZM449 504C439.059 504 431 512.059 431 522C431 531.941 439.059 540 449 540C458.941 540 467 531.941 467 522C467 512.059 458.941 504 449 504Z" fill="white"/>
      <path d="M537.5 491C550.479 491 561 501.521 561 514.5C561 527.479 550.479 538 537.5 538C524.521 538 514 527.479 514 514.5C514 501.521 524.521 491 537.5 491ZM536 498C526.059 498 518 506.059 518 516C518 525.941 526.059 534 536 534C545.941 534 554 525.941 554 516C554 506.059 545.941 498 536 498Z" fill="white"/>
